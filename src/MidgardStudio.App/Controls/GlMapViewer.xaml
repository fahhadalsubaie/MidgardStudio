<UserControl x:Class="MidgardStudio.App.Controls.GlMapViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:glwpf="clr-namespace:OpenTK.Wpf;assembly=GLWpfControl">
    <UserControl.Resources>
        <Style x:Key="SwatchButton" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                BorderBrush="#55FFFFFF" BorderThickness="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <glwpf:GLWpfControl x:Name="Surface" Ready="OnReady" Render="OnRender" />
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                Background="#CC1E1E28" CornerRadius="6" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="Reset" Click="OnResetViewClick" Padding="8,2" Margin="0,0,4,0"
                        ToolTip="Reset view (or double-click the map)" />
                <ToggleButton x:Name="WireToggle" Content="Wire" Click="OnWireframeToggled" Padding="8,2"
                              ToolTip="Wireframe" />
                <Border Width="1" Background="#40FFFFFF" Margin="6,1" />
                <Button Style="{StaticResource SwatchButton}" Background="#1A1A22" Tag="#1A1A22" Click="OnBackgroundClick" ToolTip="Dark" />
                <Button Style="{StaticResource SwatchButton}" Background="#000000" Tag="#000000" Click="OnBackgroundClick" ToolTip="Black" />
                <Button Style="{StaticResource SwatchButton}" Background="#5A7AA0" Tag="#5A7AA0" Click="OnBackgroundClick" ToolTip="Sky" />
                <Button Style="{StaticResource SwatchButton}" Background="#FFFFFF" Tag="#FFFFFF" Click="OnBackgroundClick" ToolTip="White" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

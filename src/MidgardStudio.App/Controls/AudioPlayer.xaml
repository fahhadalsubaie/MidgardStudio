<UserControl x:Class="MidgardStudio.App.Controls.AudioPlayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="320" Margin="20">
            <TextBlock Text="♪" FontSize="46" Opacity="0.28" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock x:Name="StateText" HorizontalAlignment="Center" Margin="0,8,0,0" Opacity="0.6"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
                <ui:Button x:Name="PlayButton" Appearance="Primary" Click="OnPlayPause"
                           Width="44" Height="44" Padding="0" Content="❚❚" FontSize="15" />
                <TextBlock x:Name="TimeText" Text="0:00 / 0:00" VerticalAlignment="Center" Margin="14,0,0,0"
                           FontFamily="Consolas" Opacity="0.75" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </StackPanel>

            <Slider x:Name="Seek" Margin="0,14,0,0" Minimum="0" Maximum="1" Width="320" IsMoveToPointEnabled="True"
                    Thumb.DragStarted="OnSeekDragStarted" Thumb.DragCompleted="OnSeekDragCompleted" />

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                <TextBlock Text="Vol" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.55"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <Slider x:Name="Vol" Minimum="0" Maximum="1" Value="0.8" Width="110"
                        VerticalAlignment="Center" ValueChanged="OnVolumeChanged" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>

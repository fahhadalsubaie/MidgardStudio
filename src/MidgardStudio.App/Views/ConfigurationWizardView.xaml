<UserControl x:Class="MidgardStudio.App.Views.ConfigurationWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ConfigurationWizardViewModel}">

    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Recent profiles -->
        <DockPanel Grid.Column="0" Margin="0,0,16,0">
            <TextBlock DockPanel.Dock="Top" Text="Profiles" Style="{StaticResource TitleSection}" Margin="2,0,0,8" />
            <ui:Button DockPanel.Dock="Bottom" Content="New profile" Command="{Binding NewProfileCommand}"
                       HorizontalAlignment="Stretch" Margin="0,8,0,0">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
            </ui:Button>
            <Border BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="6">
                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="8,6" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding DefaultMode}" Opacity="0.55" FontSize="11" />
                                    <TextBlock Text="{Binding Paths.ServerDbRoot}" Opacity="0.5" FontSize="10.5"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <ui:Button Grid.Column="1" Appearance="Transparent" VerticalAlignment="Top"
                                           ToolTip="Delete profile"
                                           Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                           CommandParameter="{Binding}">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                                </ui:Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </DockPanel>

        <!-- Profile editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>
                <TextBlock Text="Workspace configuration" Style="{StaticResource TitleScreen}" />
                <TextBlock Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,16"
                           Text="Point the app at this server's files. The GRF archives set here are what the GRF Browser reads — you don't set them again there. Choose the ruleset to hide the other system's fields." />

                <TextBlock Text="Profile name" Opacity="0.85" Margin="0,0,0,2" />
                <ui:TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" MaxWidth="360" HorizontalAlignment="Left" />

                <TextBlock Text="System" Opacity="0.85" Margin="0,14,0,4" />
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Renewal" GroupName="System" IsChecked="{Binding IsRenewal}" Margin="0,0,20,0" />
                    <RadioButton Content="Pre-Renewal" GroupName="System"
                                 IsChecked="{Binding IsRenewal, Converter={StaticResource InverseBool}}" />
                </StackPanel>

                <TextBlock Text="Server DB folder  (…\server-db\db)" Opacity="0.85" Margin="0,14,0,2" />
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Content="Browse…" Command="{Binding BrowseServerDbCommand}" Margin="8,0,0,0" />
                    <ui:TextBox Text="{Binding ServerDbRoot, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>

                <TextBlock Text="Client lua-files folder" Opacity="0.85" Margin="0,12,0,2" />
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Content="Browse…" Command="{Binding BrowseLuaFilesCommand}" Margin="8,0,0,0" />
                    <ui:TextBox Text="{Binding LuaFilesRoot, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>

                <TextBlock Text="Base item info  (itemInfo.lua — core/official, read for text &amp; icons)" Opacity="0.85" Margin="0,12,0,2" />
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Content="Browse…" Command="{Binding BrowseItemInfoCommand}" Margin="8,0,0,0" />
                    <ui:TextBox Text="{Binding ItemInfoPath, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="…\System\itemInfo.lua (optional)" />
                </DockPanel>

                <TextBlock Text="Custom item info  (itemInfo_C.lua — written for new/overridden items)" Opacity="0.85" Margin="0,12,0,2" />
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Content="Browse…" Command="{Binding BrowseItemInfoCustomCommand}" Margin="8,0,0,0" />
                    <ui:TextBox Text="{Binding ItemInfoCustomPath, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="…\System\itemInfo_C.lua (leave empty to write into the base file)" />
                </DockPanel>

                <DockPanel Margin="0,16,0,2">
                    <TextBlock Text="GRF archives &amp; data folders" Opacity="0.85" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="Add GRF…" Command="{Binding AddGrfCommand}" Margin="0,0,6,0">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="FolderZip24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Add data folder…" Command="{Binding AddDataFolderCommand}" />
                    </StackPanel>
                </DockPanel>
                <Border BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="6" MinHeight="64" Padding="4">
                    <ItemsControl ItemsSource="{Binding GrfPaths}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="2">
                                    <ui:Button DockPanel.Dock="Right" Appearance="Transparent" ToolTip="Remove"
                                               Command="{Binding DataContext.RemoveGrfCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" FontFamily="Consolas" FontSize="11"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
                <TextBlock Opacity="0.5" FontSize="11" Margin="2,4,0,0"
                           Text="Layered last-wins (a loose data folder added last overrides the GRFs). Optional — leave empty to skip GRF previews." />

                <TextBlock Text="{Binding StatusMessage}" Foreground="#7FD0A0" TextWrapping="Wrap" Margin="0,14,0,0"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}" />

                <StackPanel Orientation="Horizontal" Margin="0,18,0,4">
                    <ui:Button Content="Save profile" Command="{Binding SaveProfileCommand}" Margin="0,0,10,0">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Open" Appearance="Primary" Command="{Binding OpenCommand}" Margin="0,0,10,0">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Open24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Cancel" Command="{Binding CancelCommand}"
                               Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<ui:FluentWindow x:Class="MidgardStudio.App.Views.IconPickerDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
                 mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=vm:IconPickerViewModel}"
                 Title="Choose an icon"
                 Width="660" Height="620"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False">

    <ui:FluentWindow.Resources>
        <!-- Themed, non-dark-on-dark tabs: the active one carries an electric, pulsing accent underline. -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#B8B8C4" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="root" CornerRadius="8" Padding="18,9" Background="#16FFFFFF"
                                BorderBrush="#26FFFFFF" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect x:Name="rootGlow" Color="#9B7BE0" BlurRadius="0" ShadowDepth="0" Opacity="0" />
                            </Border.Effect>
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.FontSize="13" TextElement.FontWeight="SemiBold" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter TargetName="root" Property="Background" Value="#2E9B7BE0" />
                                <Setter TargetName="root" Property="BorderBrush" Value="#9E9B7BE0" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="glowSb">
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <ColorAnimation Storyboard.TargetName="rootGlow" Storyboard.TargetProperty="Color"
                                                            From="#6FD0FF" To="#C77BFF" Duration="0:0:0.9" />
                                            <DoubleAnimation Storyboard.TargetName="rootGlow" Storyboard.TargetProperty="Opacity"
                                                            From="0.45" To="0.95" Duration="0:0:0.9" />
                                            <DoubleAnimation Storyboard.TargetName="rootGlow" Storyboard.TargetProperty="BlurRadius"
                                                            From="8" To="20" Duration="0:0:0.9" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="glowSb" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Choose an icon" />

        <TabControl Grid.Row="1" Margin="14,0,14,8">
            <!-- Copy an existing item's icon -->
            <TabItem Header="Copy from an item">
                <DockPanel Margin="0,8,0,0">
                    <ui:TextBox DockPanel.Dock="Top" Margin="0,0,0,8"
                                Text="{Binding ItemSearch, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Search by item ID or name…">
                        <ui:TextBox.Icon><ui:SymbolIcon Symbol="Search24" /></ui:TextBox.Icon>
                    </ui:TextBox>
                    <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <TextBlock Text="{Binding ItemCountText}" Opacity="0.55" FontSize="11" VerticalAlignment="Center" />
                        <ui:Button Content="Use this icon" Appearance="Primary" HorizontalAlignment="Right"
                                   Command="{Binding PickItemCommand}" MinWidth="110" />
                    </DockPanel>
                    <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                             VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent">
                        <ListBox.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding PickItemCommand}" />
                        </ListBox.InputBindings>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="3" Background="#22000000"
                                            BorderBrush="#22FFFFFF" BorderThickness="1" Margin="0,0,8,0">
                                        <Image Source="{Binding Icon}" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Display}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Resource}" Opacity="0.5" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>

            <!-- Browse the icons in one GRF / loose data source -->
            <TabItem Header="Browse GRF icons">
                <DockPanel Margin="0,8,0,0">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}"
                                  DisplayMemberPath="Name" IsEnabled="{Binding HasSources}"
                                  ToolTip="{Binding SelectedSource.Path}" />
                        <ui:TextBox Grid.Column="2" Text="{Binding GrfSearch, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Search icon name…">
                            <ui:TextBox.Icon><ui:SymbolIcon Symbol="Search24" /></ui:TextBox.Icon>
                        </ui:TextBox>
                    </Grid>
                    <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <TextBlock Text="{Binding GrfCountText}" Opacity="0.55" FontSize="11" VerticalAlignment="Center" />
                        <ui:Button Content="Use this icon" Appearance="Primary" HorizontalAlignment="Right"
                                   Command="{Binding PickGrfCommand}" MinWidth="110" />
                    </DockPanel>
                    <Grid>
                        <ListBox ItemsSource="{Binding GrfIcons}" SelectedItem="{Binding SelectedGrfIcon}"
                                 VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent">
                            <ListBox.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding PickGrfCommand}" />
                            </ListBox.InputBindings>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="3" Background="#22000000"
                                                BorderBrush="#22FFFFFF" BorderThickness="1" Margin="0,0,8,0">
                                            <Image Source="{Binding Icon}" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding LoadingGrf, Converter={StaticResource BoolToVis}}">
                            <ui:ProgressRing IsIndeterminate="True" Width="28" Height="28" />
                            <TextBlock Text="Loading icons…" Opacity="0.6" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="14">
            <ui:Button Content="Cancel" Command="{Binding CancelCommand}" MinWidth="92" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>

<ui:FluentWindow x:Class="MidgardStudio.App.Views.SpritePickerDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
                 mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=vm:SpritePickerViewModel}"
                 Title="Choose a headgear sprite"
                 Width="540" Height="560"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Choose a headgear sprite" />

        <DockPanel Grid.Row="1" Margin="14,4,14,8">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}"
                          DisplayMemberPath="Name" IsEnabled="{Binding HasSources}"
                          ToolTip="{Binding SelectedSource.Path}" />
                <ui:TextBox Grid.Column="2" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Search sprite name…">
                    <ui:TextBox.Icon><ui:SymbolIcon Symbol="Search24" /></ui:TextBox.Icon>
                </ui:TextBox>
            </Grid>

            <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <TextBlock Text="{Binding CountText}" Opacity="0.55" FontSize="11" VerticalAlignment="Center" />
                <ui:Button Content="Use this sprite" Appearance="Primary" HorizontalAlignment="Right"
                           Command="{Binding PickCommand}" MinWidth="120" />
            </DockPanel>

            <Grid>
                <ListBox ItemsSource="{Binding Sprites}" SelectedItem="{Binding SelectedSprite}"
                         VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent">
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding PickCommand}" />
                    </ListBox.InputBindings>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" Margin="2,3" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding Loading, Converter={StaticResource BoolToVis}}">
                    <ui:ProgressRing IsIndeterminate="True" Width="28" Height="28" />
                    <TextBlock Text="Loading sprites…" Opacity="0.6" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </DockPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="14">
            <ui:Button Content="Cancel" Command="{Binding CancelCommand}" MinWidth="92" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>

<UserControl x:Class="MidgardStudio.App.Views.DbWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
             xmlns:common="clr-namespace:MidgardStudio.App.Common"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DbWorkspaceViewModel}">

    <Grid>
        <!-- Loading overlay -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" />
            <TextBlock Text="Loading database…" Opacity="0.7" Margin="0,12,0,0" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Main content -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="300" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <!-- Master list -->
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                        <ui:Button Command="{Binding AddCustomCommand}" Margin="0,0,4,0" ToolTip="Add a new custom entry">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Command="{Binding DuplicateCommand}" Margin="0,0,4,0" ToolTip="Duplicate the selected entry as a new custom">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Copy24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Command="{Binding CopyEntryCommand}" Margin="0,0,4,0" ToolTip="Copy the selected entry as YAML to the clipboard">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="ClipboardLink24" /></ui:Button.Icon>
                        </ui:Button>
                        <ToggleButton IsChecked="{Binding List.OverriddenOnly, Mode=TwoWay}"
                                      ToolTip="Show only your custom / overridden entries">
                            <ui:SymbolIcon Symbol="Filter24" />
                        </ToggleButton>
                    </StackPanel>
                    <ui:TextBox Grid.Column="1" Tag="ListSearch" PlaceholderText="Search id / aegis / name / type…  (Ctrl+F)"
                                Text="{Binding List.SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                </Grid>

                <TextBlock DockPanel.Dock="Bottom" Text="{Binding List.StatusText}" Opacity="0.6"
                           Margin="2,6,0,0" FontSize="11" />

                <ListView x:Name="MasterList" ItemsSource="{Binding List.Rows}"
                          SelectedItem="{Binding List.SelectedRow, Mode=TwoWay}"
                          Background="Transparent" BorderThickness="0"
                          ItemContainerStyle="{StaticResource MasterListItem}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                          ScrollViewer.IsDeferredScrollingEnabled="False"
                          common:ListBehaviors.SelectOnRightClick="True">
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Restore to default"
                                      Visibility="{Binding PlacementTarget.DataContext.CanRestore, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}"
                                      Command="{Binding PlacementTarget.DataContext.RestoreToDefaultCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      ToolTip="Discard customizations and revert this entry to its base values">
                                <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowUndo24" /></MenuItem.Icon>
                            </MenuItem>
                            <Separator Visibility="{Binding PlacementTarget.DataContext.CanRestore, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                            <MenuItem Header="Copy YAML"
                                      Command="{Binding PlacementTarget.DataContext.CopyEntryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Change ID…"
                                      Command="{Binding PlacementTarget.DataContext.ChangeIdCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Copy to ID…"
                                      Command="{Binding PlacementTarget.DataContext.CopyToIdCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Delete"
                                      Command="{Binding PlacementTarget.DataContext.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <Separator Visibility="{Binding PlacementTarget.DataContext.IsItemDb, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                            <MenuItem Header="Select in Client Items"
                                      Visibility="{Binding PlacementTarget.DataContext.IsItemDb, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}"
                                      Command="{Binding PlacementTarget.DataContext.SelectInClientItemsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Add in Client Items"
                                      Visibility="{Binding PlacementTarget.DataContext.IsItemDb, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}"
                                      Command="{Binding PlacementTarget.DataContext.AddInClientItemsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="5,1" HorizontalAlignment="Left"
                                                Background="{Binding Origin, Converter={StaticResource OriginBrush}}">
                                            <TextBlock Text="{Binding Origin, Converter={StaticResource OriginLabel}}"
                                                       FontSize="9.5" FontWeight="SemiBold" Foreground="White" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="" Width="30">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding Icon}" Width="22" Height="22"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn x:Name="IdColumn" Header="ID" Width="60" DisplayMemberBinding="{Binding KeyText}" />
                            <GridViewColumn x:Name="NameColumn" Header="Name" Width="166" DisplayMemberBinding="{Binding Name}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="#22FFFFFF" />

            <!-- Detail editor -->
            <Grid Grid.Column="2" Margin="8,0,0,0">
                <TextBlock Text="Select an entry to view or edit." Opacity="0.5"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding Editor.HasRecord, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                <DockPanel Visibility="{Binding Editor.HasRecord, Converter={StaticResource BoolToVis}}">
                    <!-- Record identity header removed: the list already shows the selected entry + its origin. -->

                    <ui:InfoBar DockPanel.Dock="Top" Severity="Informational" IsClosable="True" Margin="0,0,0,8"
                                Title="Info" Message="{Binding PortReportText}"
                                IsOpen="{Binding PortReportText, Converter={StaticResource StringToBool}}" />

                    <!-- Client sprite registration (mobs only) -->
                    <ui:CardExpander DockPanel.Dock="Bottom" Header="Client sprite" IsExpanded="True"
                                     Margin="0,8,0,0"
                                     Visibility="{Binding SideEditor, Converter={StaticResource NotNullToVis}}">
                        <ContentControl Content="{Binding SideEditor}" />
                    </ui:CardExpander>

                    <!-- Two field cards (groups balanced across them); drop table sits below -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ItemsControl Grid.Column="0" ItemsSource="{Binding Editor.LeftColumn}" VerticalAlignment="Top" />
                                <ItemsControl Grid.Column="2" ItemsSource="{Binding Editor.RightColumn}" VerticalAlignment="Top" />
                            </Grid>
                            <ContentControl Content="{Binding AuxEditor}" Margin="0,10,0,0"
                                            Visibility="{Binding AuxEditor, Converter={StaticResource NotNullToVis}}" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="MidgardStudio.App.Views.MapCacheEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
             xmlns:common="clr-namespace:MidgardStudio.App.Common"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MapCacheEditorViewModel}">

    <DockPanel>
        <!-- Header + toolbar -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Map Cache Editor" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Opacity="0.65" FontSize="12" TextWrapping="Wrap"
                           Text="Read-only base from re + pre-re. Add maps from .gat, merge another map_cache.dat, then Save — edits are written only to db/import/map_cache.dat." />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <ui:Button Content="Add .gat maps…" Command="{Binding AddGatCommand}" Margin="0,0,8,0">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Merge .dat…" Command="{Binding MergeDatCommand}" Margin="0,0,8,0">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="FolderZip24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Reload" Command="{Binding ReloadCommand}" Margin="0,0,8,0">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowClockwise24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Open folder" Command="{Binding OpenFolderCommand}" Margin="0,0,8,0">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Folder24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Save to import" Appearance="Primary" Command="{Binding SaveCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- Status / dirty -->
        <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Opacity="0.75" FontSize="12" TextWrapping="Wrap" />
            <TextBlock HorizontalAlignment="Right" Foreground="#E0A030" FontSize="12"
                       Text="● Unsaved map-cache changes"
                       Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}" />
        </Grid>

        <ui:TextBox DockPanel.Dock="Top" Margin="0,0,0,8" PlaceholderText="Search maps…"
                    Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" />

        <Border BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="6" Background="#0AFFFFFF">
            <ListView x:Name="MapList" ItemsSource="{Binding Rows}" SelectedItem="{Binding Selected, Mode=TwoWay}"
                      Background="Transparent" BorderThickness="0"
                      ItemContainerStyle="{StaticResource MasterListItem}"
                      common:ScrollSound.Enabled="True"
                      ScrollViewer.VerticalScrollBarVisibility="Visible">
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Remove from import"
                                  Command="{Binding PlacementTarget.DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                        <GridViewColumn x:Name="MapColumn" Header="Map" Width="200" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="Size" Width="110" DisplayMemberBinding="{Binding SizeText}" />
                        <GridViewColumn Header="Cells" Width="90" DisplayMemberBinding="{Binding CellsText}" />
                        <GridViewColumn x:Name="OriginColumn" Header="Origin" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,1" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#6B7280" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Origin}" Value="Custom">
                                                        <Setter Property="Background" Value="#2EB88A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Origin}" Value="Override">
                                                        <Setter Property="Background" Value="#E0A030" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Origin}" FontSize="10.5" FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </DockPanel>
</UserControl>

<UserControl x:Class="MidgardStudio.App.Views.CashShopManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CashShopManagerViewModel}">

    <DockPanel>
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,18,0,14">
            <TextBlock Text="Cash Shop Manager" Style="{StaticResource TitleScreen}" />
            <TextBlock Opacity="0.65" FontSize="12" TextWrapping="Wrap"
                       Text="Add items to each tab by name, Aegis name, or ID and set a cash-point price. Drag cards to reorder, or drop one on another tab to move it." />
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Tab rail (also a drop target: drop a card here to recategorize it) -->
            <Border Grid.Column="0" Margin="0,0,12,0" CornerRadius="10" Background="#14FFFFFF" Padding="6">
                <ListBox x:Name="TabRail" ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0" AllowDrop="True"
                         DragOver="TabRail_DragOver" Drop="TabRail_Drop"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="AllowDrop" Value="True" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CashTabViewModel}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" />
                                <Border Grid.Column="1" CornerRadius="9" Padding="7,1" MinWidth="22"
                                        Background="#332B1F4D" BorderBrush="#4C3C72" BorderThickness="1"
                                        HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Count}" FontSize="11" Foreground="#BBA9E6"
                                               HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Item editor for the selected tab -->
            <DockPanel Grid.Column="1">

                <!-- Add row (item_db autocomplete + bulk add) -->
                <ui:Card DockPanel.Dock="Top" Margin="0,0,0,10" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0,0,8,0">
                            <ui:TextBox x:Name="AddBox"
                                        PlaceholderText="Item name, Aegis name, or ID — type to search (comma-separate to bulk-add)"
                                        Text="{Binding NewItemName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PreviewKeyDown="AddBox_PreviewKeyDown"
                                        LostKeyboardFocus="AddBox_LostKeyboardFocus" />
                            <!-- item_db autocomplete popup -->
                            <Popup IsOpen="{Binding IsSuggestOpen}" PlacementTarget="{Binding ElementName=AddBox}"
                                   Placement="Bottom" AllowsTransparency="True" StaysOpen="True"
                                   Width="{Binding ActualWidth, ElementName=AddBox}" PopupAnimation="Fade">
                                <Border Background="#FF26262E" BorderBrush="#40FFFFFF" BorderThickness="1"
                                        CornerRadius="6" Margin="0,2,0,0">
                                    <ListBox x:Name="SuggestList" ItemsSource="{Binding ItemSuggestions}" MaxHeight="280"
                                             Background="Transparent" BorderThickness="0"
                                             PreviewMouseLeftButtonUp="SuggestList_PreviewMouseLeftButtonUp">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="3,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="30" Height="30" CornerRadius="5" Margin="0,0,9,0"
                                                            Background="#22000000" VerticalAlignment="Center">
                                                        <Grid>
                                                            <ui:SymbolIcon Symbol="Tag24" FontSize="14" Opacity="0.45"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Visibility="{Binding HasNoIcon, Converter={StaticResource BoolToVis}}" />
                                                            <Image Source="{Binding Icon}" Width="26" Height="26"
                                                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Visibility="{Binding Name, Converter={StaticResource StringToVis}}" />
                                                        <TextBlock FontFamily="Consolas" FontSize="10" Opacity="0.6" TextTrimming="CharacterEllipsis">
                                                            <Run Text="{Binding AegisName, Mode=OneWay}" /><Run Text="  ·  #" /><Run Text="{Binding Id, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                        <ui:TextBox Grid.Column="1" Margin="0,0,8,0" PlaceholderText="Price"
                                    Text="{Binding NewItemPriceText, UpdateSourceTrigger=PropertyChanged}">
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding AddItemCommand}" />
                            </ui:TextBox.InputBindings>
                        </ui:TextBox>
                        <ui:Button Grid.Column="2" Content="Add" Appearance="Primary" Command="{Binding AddItemCommand}"
                                   ToolTip="Add to the selected tab (undoable; written to import on Save). Paste several names separated by commas to bulk-add.">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                        </ui:Button>
                    </Grid>
                </ui:Card>

                <!-- Status line -->
                <TextBlock DockPanel.Dock="Bottom" Margin="2,8,0,0" Opacity="0.7" FontSize="12"
                           Text="{Binding StatusMessage}" />

                <Grid>
                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420"
                                Visibility="{Binding HasNoItems, Converter={StaticResource BoolToVis}}">
                        <Border Width="92" Height="92" CornerRadius="46" HorizontalAlignment="Center"
                                Background="#1A8D2DF2" BorderBrush="#3A8D2DF2" BorderThickness="1">
                            <ui:SymbolIcon Symbol="Cart24" FontSize="42" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="#BBA9E6" />
                        </Border>
                        <TextBlock Text="This tab is empty" HorizontalAlignment="Center" Margin="0,14,0,4"
                                   FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Opacity="0.6" TextAlignment="Center" TextWrapping="Wrap"
                                   Text="Add an item by its Aegis name above to put it on sale here — or drag a card in from another tab." />
                    </StackPanel>

                    <!-- Virtualized card grid -->
                    <ListBox x:Name="ItemsList" ItemsSource="{Binding Items}" Background="Transparent" BorderThickness="0"
                             AllowDrop="True" DragOver="Items_DragOver" Drop="Items_Drop"
                             GiveFeedback="Items_GiveFeedback"
                             PreviewMouseLeftButtonDown="Items_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="Items_PreviewMouseMove"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ui:VirtualizingWrapPanel Orientation="Vertical" ItemSize="258,140" SpacingMode="Uniform" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CashItemRowViewModel}">
                                <!-- Glass card -->
                                <Border x:Name="Card" Width="244" Height="126" Margin="7" CornerRadius="12" Padding="12"
                                        Background="#16FFFFFF" BorderBrush="#26FFFFFF" BorderThickness="1">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="CardLift" Y="0" />
                                    </Border.RenderTransform>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Icon + name + id -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="9" Margin="0,0,12,0"
                                                    Background="#22000000" VerticalAlignment="Center">
                                                <Grid>
                                                    <ui:SymbolIcon Symbol="Tag24" FontSize="22" Opacity="0.5"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Visibility="{Binding HasNoIcon, Converter={StaticResource BoolToVis}}" />
                                                    <Image Source="{Binding Icon}" Width="44" Height="44"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,24,0">
                                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}" />
                                                <TextBlock Text="{Binding IdLabel}" FontFamily="Consolas" FontSize="11" Opacity="0.6"
                                                           Margin="0,3,0,0"
                                                           Visibility="{Binding HasId, Converter={StaticResource BoolToVis}}" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- Price pill + remove -->
                                        <Grid Grid.Row="1" Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="9" Padding="10,3" HorizontalAlignment="Left"
                                                    Background="#262B1F4D" BorderBrush="#4C3C72" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Money24" FontSize="13" Foreground="#BBA9E6"
                                                                   VerticalAlignment="Center" Margin="0,0,5,0" />
                                                    <TextBox Text="{Binding PriceText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             IsEnabled="{Binding IsEditable}" MinWidth="52"
                                                             Background="Transparent" BorderThickness="0" Padding="0"
                                                             Foreground="#E8DEFF" FontSize="13" VerticalContentAlignment="Center"
                                                             ToolTip="Price in cash points (#CASHPOINTS)." />
                                                </StackPanel>
                                            </Border>
                                            <ui:Button x:Name="RemoveBtn" Grid.Column="1" Appearance="Secondary" Padding="6"
                                                       Opacity="0"
                                                       Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       CommandParameter="{Binding}"
                                                       Visibility="{Binding IsEditable, Converter={StaticResource BoolToVis}}"
                                                       ToolTip="Remove this item from the tab.">
                                                <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" FontSize="14" /></ui:Button.Icon>
                                            </ui:Button>
                                        </Grid>

                                        <!-- Floating top-right: base tag + validation badge (always visible, never clipped) -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                            <Border CornerRadius="5" Padding="5,0" Background="#22000000" Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IsBase, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="base" FontSize="9" Opacity="0.6" />
                                            </Border>
                                            <ui:SymbolIcon Symbol="Warning24" FontSize="16" VerticalAlignment="Center"
                                                           ToolTip="{Binding IssueTooltip}">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Issue}" Value="Warning">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Setter Property="Foreground" Value="#E0A53A" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Issue}" Value="Error">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Setter Property="Foreground" Value="#E5564E" />
                                                                <Setter Property="Symbol" Value="ErrorCircle24" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Hover: lift the card + reveal the remove button -->
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="Card" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Card" Property="Background" Value="#22FFFFFF" />
                                        <Setter TargetName="Card" Property="BorderBrush" Value="#558D2DF2" />
                                        <Setter TargetName="RemoveBtn" Property="Opacity" Value="1" />
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="CardLift" Storyboard.TargetProperty="Y"
                                                                     To="-2" Duration="0:0:0.12" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="CardLift" Storyboard.TargetProperty="Y"
                                                                     To="0" Duration="0:0:0.12" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>

<ui:FluentWindow x:Class="MidgardStudio.App.Views.DropEditDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Drop edit"
                 Width="380" SizeToContent="Height"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Drop edit" />

        <StackPanel Grid.Row="1" Margin="16,8,16,16">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Item ID" VerticalAlignment="Center" Opacity="0.85" />
                <ui:TextBox x:Name="IdBox" Grid.Column="1" />
                <ui:Button x:Name="PickButton" Grid.Column="2" Content="…" Margin="6,0,0,0" MinWidth="36" />
            </Grid>

            <TextBlock x:Name="ItemNameText" Margin="96,0,0,4" Opacity="0.6" FontSize="11" />

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Drop chance" VerticalAlignment="Center" Opacity="0.85"
                           ToolTip="Per 10000 — 2000 = 20.00%" />
                <ui:TextBox x:Name="RateBox" Grid.Column="1" />
            </Grid>
            <TextBlock x:Name="RatePercentText" Margin="96,0,0,4" Opacity="0.6" FontSize="11" />

            <CheckBox x:Name="StealBox" Content="Steal protected" Margin="96,4,0,0" />

            <Grid x:Name="RandRow" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Rand group" VerticalAlignment="Center" Opacity="0.85" />
                <ui:TextBox x:Name="RandBox" Grid.Column="1" />
            </Grid>

            <TextBlock x:Name="ErrorText" Foreground="#E0746A" Margin="0,10,0,0" TextWrapping="Wrap"
                       Visibility="Collapsed" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <ui:Button x:Name="OkButton" Content="Ok" Appearance="Primary" MinWidth="84" Margin="0,0,8,0" />
                <ui:Button x:Name="CancelButton" Content="Cancel" MinWidth="84" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>

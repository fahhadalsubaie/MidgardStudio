<ui:FluentWindow x:Class="MidgardStudio.App.Views.BonusBuilderDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
                 Title="Bonus builder"
                 Width="720" Height="520"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False"
                 d:DataContext="{d:DesignInstance Type=vm:BonusBuilderViewModel}"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Bonus builder" />

        <Grid Grid.Row="1" Margin="16,4,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Bonus list -->
            <DockPanel Grid.Column="0">
                <ui:TextBox DockPanel.Dock="Top" PlaceholderText="Search bonuses…" Margin="0,0,0,8"
                            Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" />
                <Border BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="6">
                    <ListBox ItemsSource="{Binding Definitions}" SelectedItem="{Binding Selected, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <TextBlock Text="{Binding Display}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Name}" Opacity="0.5" FontSize="11" FontFamily="Consolas" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- Parameters + preview -->
            <DockPanel Grid.Column="2">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="{Binding Selected.Display}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Selected.Name}" Opacity="0.5" FontFamily="Consolas" Margin="0,2,0,10" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom" BorderBrush="#2EFFFFFF" BorderThickness="1" CornerRadius="6"
                        Background="#1A000000" Padding="10,8" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Generated bonus" Opacity="0.55" FontSize="11" Margin="0,0,0,4" />
                        <TextBox Text="{Binding Preview, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                                 Background="Transparent" FontFamily="Consolas" FontSize="13.5" Foreground="#9CDCFE"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Inputs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Opacity="0.85" />

                                    <ComboBox Grid.Column="1" ItemsSource="{Binding Options}" DisplayMemberPath="Label"
                                              SelectedValuePath="Value" SelectedValue="{Binding Value, Mode=TwoWay}"
                                              Visibility="{Binding IsEnum, Converter={StaticResource BoolToVis}}" />
                                    <ui:TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                Visibility="{Binding IsNumber, Converter={StaticResource BoolToVis}}" />
                                    <ui:TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="e.g. AL_HEAL"
                                                Visibility="{Binding IsText, Converter={StaticResource BoolToVis}}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,12,16,16">
            <ui:Button x:Name="InsertButton" Content="Insert bonus" Appearance="Primary" MinWidth="110" Margin="0,0,8,0" />
            <ui:Button x:Name="CancelButton" Content="Cancel" MinWidth="84" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>

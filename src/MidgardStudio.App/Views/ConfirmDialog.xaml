<ui:FluentWindow x:Class="MidgardStudio.App.Views.ConfirmDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Confirm"
                 Width="440" SizeToContent="Height"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="Bar" Grid.Row="0" Title="Confirm" />

        <StackPanel Grid.Row="1" Margin="20,8,20,18">
            <TextBlock x:Name="MessageText" TextWrapping="Wrap" Margin="0,0,0,18" LineHeight="20" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="YesButton" Content="Yes" Appearance="Primary" MinWidth="96" Margin="0,0,8,0" />
                <ui:Button x:Name="AltButton" Content="Don't save" MinWidth="96" Margin="0,0,8,0" Visibility="Collapsed" />
                <ui:Button x:Name="NoButton" Content="Cancel" MinWidth="96" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>

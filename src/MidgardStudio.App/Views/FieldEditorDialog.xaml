<ui:FluentWindow x:Class="MidgardStudio.App.Views.FieldEditorDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:common="clr-namespace:MidgardStudio.App.Common"
                 Title="Edit"
                 Width="820" Height="620" MinWidth="520" MinHeight="340"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False">
    <ui:FluentWindow.Resources>
        <common:FullEditorTemplateSelector x:Key="FullEditorSelector" />
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="TitleBarCtl" Grid.Row="0" Title="Edit" />

        <!-- No outer ScrollViewer: each full template manages its own scrolling so list editors can
             virtualize (an enclosing ScrollViewer would give them infinite height and realize every row). -->
        <ContentControl Grid.Row="1" x:Name="Host" Margin="14,4,14,0"
                        ContentTemplateSelector="{StaticResource FullEditorSelector}" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="14">
            <ui:Button x:Name="CloseButton" Content="Done" Appearance="Primary" MinWidth="92" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>

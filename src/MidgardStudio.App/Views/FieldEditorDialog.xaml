<ui:FluentWindow x:Class="MidgardStudio.App.Views.FieldEditorDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:common="clr-namespace:MidgardStudio.App.Common"
                 Title="Edit"
                 Width="560" Height="560" MinWidth="380" MinHeight="260"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False">
    <ui:FluentWindow.Resources>
        <common:FullEditorTemplateSelector x:Key="FullEditorSelector" />
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="TitleBarCtl" Grid.Row="0" Title="Edit" />

        <ScrollViewer Grid.Row="1" Margin="14,4,14,0" VerticalScrollBarVisibility="Auto">
            <ContentControl x:Name="Host" ContentTemplateSelector="{StaticResource FullEditorSelector}" />
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="14">
            <ui:Button x:Name="CloseButton" Content="Done" Appearance="Primary" MinWidth="92" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>

<ui:FluentWindow x:Class="MidgardStudio.App.Views.ConditionalBonusBuilderDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
                 Title="Refine / Grade Bonuses"
                 Width="960" Height="680" MinWidth="760" MinHeight="520"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False"
                 d:DataContext="{d:DesignInstance Type=vm:ConditionalBonusBuilderViewModel}"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Refine / Grade Bonuses" />

        <Grid Grid.Row="1" Margin="16,4,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- ===== Builder ===== -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Bonuses that unlock as the item is refined or graded. Higher tiers stack on top."
                               Opacity="0.6" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,10" />

                    <!-- Refine -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="REFINEMENT" FontSize="10.5" FontWeight="SemiBold" Opacity="0.55" VerticalAlignment="Center" />
                        <ui:Button DockPanel.Dock="Right" HorizontalAlignment="Right" Content="Add refine tier" Appearance="Secondary"
                                   Padding="8,2" FontSize="11.5" Command="{Binding AddRefineTierCommand}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                        </ui:Button>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding RefineTiers}" Margin="0,0,0,14" />

                    <!-- Grade (renewal only) -->
                    <StackPanel Visibility="{Binding CanUseGrade, Converter={StaticResource BoolToVis}}">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="ENCHANT GRADE" FontSize="10.5" FontWeight="SemiBold" Opacity="0.55" VerticalAlignment="Center" />
                            <ui:Button DockPanel.Dock="Right" HorizontalAlignment="Right" Content="Add grade tier" Appearance="Secondary"
                                       Padding="8,2" FontSize="11.5" Command="{Binding AddGradeTierCommand}">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                            </ui:Button>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding GradeTiers}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Live preview ===== -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="GENERATED SCRIPT" FontSize="10.5" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,6" />
                <Border DockPanel.Dock="Top" Height="220" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="4" Background="#16000000" Margin="0,0,0,12">
                    <TextBox Text="{Binding ScriptPreview, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                             Background="Transparent" FontFamily="Consolas" FontSize="12" Foreground="#9FE0A0"
                             Padding="8,6" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                </Border>
                <TextBlock DockPanel.Dock="Top" Text="CLIENT DESCRIPTION" FontSize="10.5" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,6" />
                <Border BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="4" Background="#16000000">
                    <TextBox Text="{Binding DescriptionPreview, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                             Background="Transparent" FontFamily="Consolas" FontSize="12" Foreground="#C9A6FF"
                             Padding="8,6" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Border>
            </DockPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,12,16,16">
            <ui:Button x:Name="InsertButton" Content="Save to script" Appearance="Primary" MinWidth="140" Margin="0,0,8,0" />
            <ui:Button x:Name="CancelButton" Content="Cancel" MinWidth="84" />
        </StackPanel>

        <Grid.Resources>
            <!-- One tier row: threshold input (refine number / grade combo) + its bonus lines. -->
            <DataTemplate DataType="{x:Type vm:ConditionalTierViewModel}">
                <Border BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="6" Background="#0AFFFFFF" Padding="10,8" Margin="0,3">
                    <StackPanel>
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Refine +" VerticalAlignment="Center" Opacity="0.85"
                                           Visibility="{Binding IsRefine, Converter={StaticResource BoolToVis}}" />
                                <ui:TextBox Width="56" Margin="2,0,0,0" Text="{Binding Threshold, UpdateSourceTrigger=PropertyChanged}"
                                            Visibility="{Binding IsRefine, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="Grade" VerticalAlignment="Center" Opacity="0.85"
                                           Visibility="{Binding IsGrade, Converter={StaticResource BoolToVis}}" />
                                <ComboBox Width="64" Margin="6,0,0,0" ItemsSource="{Binding GradeOptions}"
                                          DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding Threshold, Mode=TwoWay}"
                                          Visibility="{Binding IsGrade, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                            <ui:Button DockPanel.Dock="Right" Content="Remove tier" Appearance="Transparent" FontSize="11" Padding="6,2"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Command="{Binding RemoveTierCommand}" />
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding Bonuses}" Margin="0,6,0,2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11.5" Opacity="0.85"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <ui:Button Grid.Column="1" Content="✕" Appearance="Transparent" FontSize="11" Padding="6,0"
                                                   VerticalAlignment="Center" ToolTip="Remove this bonus"
                                                   Command="{Binding DataContext.RemoveBonusCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                   CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ui:Button Content="Add bonus…" Appearance="Transparent" HorizontalAlignment="Left" FontSize="11.5" Padding="6,2"
                                   Command="{Binding AddBonusCommand}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </Grid.Resources>
    </Grid>
</ui:FluentWindow>

<ui:FluentWindow x:Class="MidgardStudio.App.Views.YamlPreviewDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="YAML preview"
                 Width="720" Height="600"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="TitleBarCtl" Grid.Row="0" Title="YAML preview" />

        <Border Grid.Row="1" Margin="14,4,14,0" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="6">
            <ui:TextBox x:Name="YamlBox" IsReadOnly="True" FontFamily="Consolas" FontSize="12.5"
                        TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                        BorderThickness="0" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="14">
            <ui:Button x:Name="CopyButton" Content="Copy" Margin="0,0,8,0" MinWidth="92">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Copy24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button x:Name="CloseButton" Content="Close" Appearance="Primary" MinWidth="92" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>

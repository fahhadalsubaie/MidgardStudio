<ui:FluentWindow x:Class="MidgardStudio.App.Views.SkillPickerDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Pick a skill"
                 Width="500" Height="600" MinWidth="380" MinHeight="420"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Pick a skill" />

        <ui:TextBox Grid.Row="1" x:Name="SearchBox" Margin="16,4,16,8"
                    PlaceholderText="Search skills by name or id…" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="16,0,16,10" VerticalAlignment="Center">
            <CheckBox x:Name="MonsterToggle" Content="Include monster skills" VerticalAlignment="Center" />
            <TextBlock Text="(NPC_* — not normally usable by players)" Opacity="0.5" FontSize="11.5"
                       VerticalAlignment="Center" Margin="8,0,0,0" />
        </StackPanel>

        <Border Grid.Row="3" Margin="16,0,16,0" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="6" Background="#0AFFFFFF">
            <ListBox x:Name="ResultsList" Background="Transparent" BorderThickness="0" Padding="2"
                     VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="8,5" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Display}" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Aegis}" FontFamily="Consolas" FontSize="11" Opacity="0.5" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="#33E0A030" CornerRadius="3" Padding="5,1" Margin="0,0,8,0"
                                        Visibility="{Binding IsMonster, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="MONSTER" FontSize="9" FontWeight="SemiBold" Foreground="White" />
                                </Border>
                                <TextBlock Text="{Binding Id}" Opacity="0.45" FontSize="11" FontFamily="Consolas" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,12,16,16">
            <ui:Button x:Name="OkButton" Content="Use skill" Appearance="Primary" MinWidth="110" Margin="0,0,8,0" />
            <ui:Button x:Name="CancelButton" Content="Cancel" MinWidth="84" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>

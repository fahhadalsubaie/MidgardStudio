<UserControl x:Class="MidgardStudio.App.Views.GrfBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:MidgardStudio.App.Controls"
             xmlns:common="clr-namespace:MidgardStudio.App.Common"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:GrfBrowserViewModel}">
    <UserControl.Resources>

        <!-- Transparency checkerboard behind images -->
        <DrawingBrush x:Key="Checkerboard" TileMode="Tile" Viewport="0,0,18,18" ViewportUnits="Absolute" Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#1AFFFFFF">
                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,18,18" /></GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#0CFFFFFF">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup><RectangleGeometry Rect="0,0,9,9" /><RectangleGeometry Rect="9,9,9,9" /></GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Sources list row -->
        <Style x:Key="GrfRowItem" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Margin="0,1" Padding="7,5">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#14FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7A3FD4" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Folder tree node -->
        <Style x:Key="GrfTreeItem" TargetType="{x:Type TreeViewItem}">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TreeViewItem}">
                        <StackPanel>
                            <Border x:Name="Bd" CornerRadius="6" Padding="4,5" Margin="0,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#14FFFFFF" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                                <Setter Property="Background" Value="#7A3FD4" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" Grid.Column="0" Focusable="False" ClickMode="Press"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="16" Height="16">
                                                    <Path x:Name="Chev" Data="M 0 0 L 4 4 L 0 8 Z" Width="8" Height="8" Stretch="Uniform"
                                                          Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Chev" Property="Data" Value="M 0 0 L 8 0 L 4 4 Z" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ui:SymbolIcon Grid.Column="1" Symbol="Folder24" FontSize="14" Margin="0,0,7,0" Opacity="0.85" VerticalAlignment="Center" />
                                    <ContentPresenter Grid.Column="2" ContentSource="Header" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="14,0,0,0" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact themed toggle (checkerboard / wrap) -->
        <Style x:Key="GrfToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="B" Property="Background" Value="#14FFFFFF" /></Trigger>
                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="B" Property="Background" Value="#7A3FD4" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- File table row: dark, blue selection, GridView columns -->
        <Style x:Key="GrfFileRow" TargetType="{x:Type ListViewItem}">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="2,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Margin="0,1" Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{Binding View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#14FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7A3FD4" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Background-swatch button: a clean filled color chip (no default button chrome). -->
        <Style x:Key="SwatchButton" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="3,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" CornerRadius="4" BorderBrush="#40FFFFFF" BorderThickness="1"
                                Background="{TemplateBinding Background}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="BorderBrush" Value="#CCFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="Col0" Width="206" MinWidth="150" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition x:Name="Col1" Width="316" MinWidth="180" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition x:Name="Col2" Width="*" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent"
                      VerticalAlignment="Stretch" ResizeBehavior="PreviousAndNext" />
        <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch" Background="Transparent"
                      VerticalAlignment="Stretch" ResizeBehavior="PreviousAndNext" />

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Background="#0AFFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="8" Margin="0,0,2,0">
            <Grid Margin="10,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="2,0,2,10">
                    <ui:Button DockPanel.Dock="Right" Appearance="Transparent" Padding="4" MinWidth="0"
                               Command="{Binding ReloadCommand}" ToolTip="Reload sources from the profile">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowSync24" FontSize="14" /></ui:Button.Icon>
                    </ui:Button>
                    <TextBlock Text="GRF Browser" Style="{StaticResource TitleSection}" VerticalAlignment="Center" />
                </DockPanel>

                <TextBlock Grid.Row="1" Text="ARCHIVES" Style="{StaticResource TitleMicro}"
                           Margin="2,0,0,4" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <ListBox Grid.Row="2" ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource GrfRowItem}" Background="Transparent" BorderThickness="0"
                         MaxHeight="120" Margin="0,0,0,8" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel ToolTip="{Binding}">
                                <ui:SymbolIcon DockPanel.Dock="Left" Symbol="Archive24" FontSize="14" Margin="0,0,8,0" Opacity="0.85" />
                                <TextBlock Text="{Binding Converter={StaticResource FileName}}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="3" BorderBrush="#14FFFFFF" BorderThickness="0,1,0,0" Padding="0,6,0,0">
                    <Grid>
                        <TreeView x:Name="Tree" ItemsSource="{Binding RootNodes}" BorderThickness="0" Background="Transparent"
                                  ItemContainerStyle="{StaticResource GrfTreeItem}" FontSize="12"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                        <ui:ProgressRing IsIndeterminate="True" Width="26" Height="26"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ===== File table ===== -->
        <Grid Grid.Column="2" Margin="2,0,2,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- View encoding (above the file list) -->
            <DockPanel Grid.Row="0" Margin="2,0,2,8">
                <TextBlock Text="Encoding" DockPanel.Dock="Left" VerticalAlignment="Center" Opacity="0.55" Margin="0,0,8,0" FontSize="12"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <ui:Button DockPanel.Dock="Right" Content="Go" Padding="8,4" Margin="6,0,0,0" Command="{Binding ApplyCustomEncodingCommand}"
                           Visibility="{Binding CustomEncodingVisible, Converter={StaticResource BoolToVis}}" />
                <TextBox DockPanel.Dock="Right" Text="{Binding CustomEncodingText, UpdateSourceTrigger=PropertyChanged}" Width="64"
                         VerticalContentAlignment="Center" ToolTip="Codepage number, then Enter"
                         Visibility="{Binding CustomEncodingVisible, Converter={StaticResource BoolToVis}}">
                    <TextBox.InputBindings><KeyBinding Key="Enter" Command="{Binding ApplyCustomEncodingCommand}" /></TextBox.InputBindings>
                </TextBox>
                <ComboBox ItemsSource="{Binding EncodingChoices}" SelectedItem="{Binding SelectedEncoding}"
                          DisplayMemberPath="Display" HorizontalAlignment="Stretch"
                          ToolTip="Re-decode names + contents for viewing only — never written to the GRF or data folder" />
            </DockPanel>

            <!-- Up · live filter (auto, no button) · content search -->
            <Grid Grid.Row="1" Margin="2,0,2,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0" Appearance="Transparent" Padding="6" MinWidth="0"
                           Command="{Binding UpCommand}" ToolTip="Up one folder">
                    <ui:SymbolIcon Symbol="ArrowUp24" FontSize="14" />
                </ui:Button>
                <ui:TextBox Grid.Column="1" Margin="6,0,0,0" PlaceholderText="Filter this folder…"
                            Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                <ui:Button Grid.Column="2" Margin="6,0,0,0" Appearance="Transparent" Padding="6" MinWidth="0"
                           Command="{Binding OpenSearchCommand}" ToolTip="Search file contents across the archive">
                    <ui:SymbolIcon Symbol="Search24" FontSize="14" />
                </ui:Button>
            </Grid>

            <Border Grid.Row="2" Background="#08FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="8">
                <ListView x:Name="Files" ItemsSource="{Binding Items}" Background="Transparent" BorderThickness="0"
                          ItemContainerStyle="{StaticResource GrfFileRow}" GridViewColumnHeader.Click="OnHeaderClick"
                          VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" Width="178">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Grid Width="22" Height="22" Margin="0,0,8,0">
                                                <ui:SymbolIcon FontSize="15" Opacity="0.85" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <ui:SymbolIcon.Style>
                                                        <Style TargetType="ui:SymbolIcon">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Setter Property="Symbol" Value="Document24" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                    <Setter Property="Symbol" Value="Folder24" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsUp}" Value="True">
                                                                    <Setter Property="Symbol" Value="ArrowUp24" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Thumbnail, Converter={StaticResource NotNullToVis}}" Value="Visible">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:SymbolIcon.Style>
                                                </ui:SymbolIcon>
                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                       Visibility="{Binding Thumbnail, Converter={StaticResource NotNullToVis}}" />
                                            </Grid>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Type" Width="58" DisplayMemberBinding="{Binding TypeText}" />
                            <GridViewColumn Header="Size" Width="64" DisplayMemberBinding="{Binding SizeText}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <TextBlock Grid.Row="3" Text="{Binding Status}" Opacity="0.55" Margin="2,8,0,0" FontSize="11"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
        </Grid>

        <!-- ===== Preview (largest) ===== -->
        <Border Grid.Column="4" Background="#0AFFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="8" Margin="2,0,0,0">
          <Grid>
            <Grid Margin="14">
                <!-- Placeholder -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <ui:SymbolIcon Symbol="Document24" FontSize="36" Opacity="0.22" HorizontalAlignment="Center" />
                    <TextBlock Text="Select a file to preview" Opacity="0.4" Margin="0,10,0,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </StackPanel>

                <Grid Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                            <!-- Image tools: zoom + background swatch -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center"
                                        Visibility="{Binding IsImageKind, Converter={StaticResource BoolToVis}}">
                                <ui:Button Appearance="Transparent" Padding="6,4" MinWidth="0" Content="−" FontSize="14" Command="{Binding ZoomOutCommand}" ToolTip="Zoom out" />
                                <ui:Button Appearance="Transparent" Padding="6,4" MinWidth="0" Content="1:1" FontSize="11" Command="{Binding ZoomResetCommand}" ToolTip="Actual size" />
                                <ui:Button Appearance="Transparent" Padding="6,4" MinWidth="0" Content="+" FontSize="14" Command="{Binding ZoomInCommand}" ToolTip="Zoom in" />
                                <Border Width="1" Background="#22FFFFFF" Margin="8,3" />
                                <Button Style="{StaticResource SwatchButton}" Background="{StaticResource Checkerboard}" Command="{Binding SetPreviewBackgroundCommand}" CommandParameter="checker" ToolTip="Checkerboard (transparency)" />
                                <Button Style="{StaticResource SwatchButton}" Background="Black" Command="{Binding SetPreviewBackgroundCommand}" CommandParameter="black" ToolTip="Black" />
                                <Button Style="{StaticResource SwatchButton}" Background="White" Command="{Binding SetPreviewBackgroundCommand}" CommandParameter="white" ToolTip="White" />
                                <Button Style="{StaticResource SwatchButton}" Background="Magenta" Command="{Binding SetPreviewBackgroundCommand}" CommandParameter="magenta" ToolTip="Magenta" />
                                <ToggleButton x:Name="CustomSwatchToggle" Width="22" Height="22" Margin="3,0,0,0" Cursor="Hand" ToolTip="Custom color">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border CornerRadius="4" BorderBrush="#40FFFFFF" BorderThickness="1">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FF3B30" Offset="0" /><GradientStop Color="#FFCC00" Offset="0.3" />
                                                        <GradientStop Color="#34C759" Offset="0.55" /><GradientStop Color="#0A84FF" Offset="0.8" />
                                                        <GradientStop Color="#BF5AF2" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup PlacementTarget="{Binding ElementName=CustomSwatchToggle}" Placement="Bottom" StaysOpen="False"
                                       IsOpen="{Binding IsChecked, ElementName=CustomSwatchToggle}" AllowsTransparency="True">
                                    <Border Background="#222230" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="#" VerticalAlignment="Center" Opacity="0.6" Margin="0,0,2,0"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBox x:Name="HexBox" Width="84" VerticalContentAlignment="Center">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding SetPreviewBackgroundCommand}"
                                                                CommandParameter="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" />
                                                </TextBox.InputBindings>
                                            </TextBox>
                                            <ui:Button Content="Apply" Margin="6,0,0,0" Padding="8,4" Command="{Binding SetPreviewBackgroundCommand}"
                                                       CommandParameter="{Binding Text, ElementName=HexBox}" />
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            <ToggleButton Style="{StaticResource GrfToggle}" Margin="0,0,8,0" IsChecked="{Binding WrapText}" ToolTip="Wrap lines"
                                          Visibility="{Binding ShowText, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Wrap" FontSize="11.5" />
                            </ToggleButton>
                            <ToggleButton Style="{StaticResource GrfToggle}" Margin="0,0,8,0" IsChecked="{Binding ShowDetails}" ToolTip="File details, properties + hashes">
                                <TextBlock Text="Details" FontSize="11.5" />
                            </ToggleButton>
                            <ui:Button Appearance="Transparent" Padding="8,4" Command="{Binding ExportCommand}" IsEnabled="{Binding CanExport}" ToolTip="Export this file to disk">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" Margin="0,0,5,0" />
                                    <TextBlock Text="Export" VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding PreviewTitle}" FontWeight="SemiBold" FontSize="13.5" TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{Binding PreviewSubtitle}" Opacity="0.5" FontSize="11" Margin="0,1,0,0"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                    </DockPanel>

                    <!-- Details: properties + hashes -->
                    <Border Grid.Row="1" Margin="0,0,0,12" Padding="12,10" Background="#10FFFFFF" CornerRadius="6"
                            Visibility="{Binding ShowDetails, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding DetailRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}" Opacity="0.5" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CRC32 / MD5" Opacity="0.5" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Crc32}" FontFamily="Consolas" Margin="0,0,12,0"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="{Binding Md5}" FontFamily="Consolas" TextTrimming="CharacterEllipsis" MaxWidth="240"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                </StackPanel>
                                <ui:Button Grid.Column="2" Content="Compute" Padding="8,3" Command="{Binding ComputeHashesCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Content -->
                    <Border Grid.Row="2" Background="#12000000" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <!-- Image (zoom + background swatch) -->
                            <Grid Visibility="{Binding ShowImage, Converter={StaticResource BoolToVis}}">
                                <Border Background="{StaticResource Checkerboard}" />
                                <Border Background="{Binding PreviewBackground}" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="Transparent">
                                    <Image Source="{Binding PreviewImage}" Stretch="None" Margin="20"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image.LayoutTransform>
                                            <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}" />
                                        </Image.LayoutTransform>
                                    </Image>
                                </ScrollViewer>
                            </Grid>

                            <!-- Animated sprite -->
                            <Viewbox Stretch="Uniform" StretchDirection="DownOnly" Margin="20" MaxWidth="420" MaxHeight="420"
                                     Visibility="{Binding ShowAnimation, Converter={StaticResource BoolToVis}}">
                                <controls:AnimatedSpriteImage Frames="{Binding Animation.Frames}" IntervalMs="{Binding Animation.IntervalMs}" />
                            </Viewbox>

                            <!-- Audio (.wav / .mp3) — in-memory NAudio, no temp file -->
                            <controls:AudioPlayer Data="{Binding AudioData}"
                                                  Visibility="{Binding ShowAudio, Converter={StaticResource BoolToVis}}" />

                            <!-- Map / model metadata -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14"
                                          Visibility="{Binding ShowInfo, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding InfoRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Label}" Opacity="0.5" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="RESOURCES" Style="{StaticResource TitleMicro}" Margin="0,14,0,4"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Visibility="{Binding InfoItems.Count, Converter={StaticResource CountToVis}}" />
                                    <ItemsControl ItemsSource="{Binding InfoItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Opacity="0.75" Margin="0,1"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="TEXTURES" Style="{StaticResource TitleMicro}" Margin="0,14,0,6"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Visibility="{Binding Thumbs.Count, Converter={StaticResource CountToVis}}" />
                                    <ItemsControl ItemsSource="{Binding Thumbs}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Width="76" Margin="3" ToolTip="{Binding Path}">
                                                    <Border Width="68" Height="68" Background="#16000000" CornerRadius="5">
                                                        <Image Source="{Binding Image}" Stretch="Uniform" Margin="4"
                                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" FontSize="9.5" Opacity="0.6" Margin="0,3,0,0"
                                                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Text / lua / hex (syntax-highlighted) -->
                            <avalon:TextEditor common:AvalonEditBehavior.BindableText="{Binding PreviewText, Mode=OneWay}"
                                               common:AvalonEditBehavior.HighlightExtension="{Binding PreviewExt}"
                                               IsReadOnly="True" ShowLineNumbers="True" FontFamily="Consolas" FontSize="12"
                                               Background="Transparent" Foreground="#E8E8F2" LineNumbersForeground="#6E6E88"
                                               Padding="6,4,0,0" WordWrap="{Binding WrapText}"
                                               HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                               Visibility="{Binding ShowText, Converter={StaticResource BoolToVis}}" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===== Content-search results overlay ===== -->
            <Border Background="#F00E0E14" CornerRadius="8"
                    Visibility="{Binding ShowSearch, Converter={StaticResource BoolToVis}}">
                <DockPanel Margin="14">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <ui:Button DockPanel.Dock="Right" Content="Close" Padding="8,4" Command="{Binding CloseSearchCommand}" />
                        <ui:Button DockPanel.Dock="Right" Content="Cancel" Padding="8,4" Margin="0,0,8,0" Command="{Binding CancelSearchCommand}"
                                   Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}" />
                        <ui:ProgressRing DockPanel.Dock="Right" IsIndeterminate="True" Width="18" Height="18" Margin="0,0,10,0"
                                         Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="Search results" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <ui:Button DockPanel.Dock="Right" Content="Search" Padding="10,5" Margin="6,0,0,0" Command="{Binding SearchCommand}" />
                        <ui:TextBox PlaceholderText="Search file contents across the archive…"
                                    Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                            <ui:TextBox.InputBindings><KeyBinding Key="Enter" Command="{Binding SearchCommand}" /></ui:TextBox.InputBindings>
                        </ui:TextBox>
                    </DockPanel>
                    <ListBox x:Name="SearchList" ItemsSource="{Binding SearchResults}" Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource GrfRowItem}" MouseDoubleClick="OnSearchActivate" KeyDown="OnSearchKeyDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Display}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="{Binding Path}" Opacity="0.45" FontSize="10.5" FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
          </Grid>
        </Border>
    </Grid>
</UserControl>
